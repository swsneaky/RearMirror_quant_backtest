# ============================================================
# RearMirror .gitignore
# ============================================================

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/

# Data (通过 Volume 挂载，不入库)
data/raw/
data/features/
data/stock_daily_cache/
data/stock_daily_cache_*/   # 任意测试缓存目录
stock_daily_cache/
*.parquet
*.pkl
!configs/**

# Models
models/*.json
models/*.txt
models/*.bin

# Logs
logs/

# Experiments — 重量级产物不入库
experiments/

# IDE
.vscode/
.idea/
*.swp

# OS
Thumbs.db
.DS_Store

# Database (不入库，太大)
data/*.db
data/*.db-*
data/*.db-wal
data/*.db-shm
data/*.bak*

# Results (不入库)
data/results/

# Backups
backups/

# Release packages (不入库)
*.zip
RearMirror-v0.*/
RearMirror-v0.9.0-beta/

# Cache
data/cache/

# QA (临时产物)
qa/
