# ============================================================
# RearMirror .gitignore
# ============================================================

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/

# Data
data/raw/
data/features/
data/stock_daily_cache/
data/stock_daily_cache_*/
stock_daily_cache/
*.parquet
*.pkl
!configs/**

# Models
models/*.json
models/*.txt
models/*.bin

# Logs
logs/

# Experiments
experiments/

# IDE
.vscode/
.idea/
*.swp

# OS
Thumbs.db
.DS_Store

# Database
data/*.db
data/*.db-*
data/*.db-wal
data/*.db-shm
data/*.bak*

# Results
data/results/

# Backups
backups/

# Release packages
*.zip
RearMirror-v0.*/
RearMirror-v0.9.0-beta/

# Cache
data/cache/

# QA
qa/

# Internal collaboration artifacts (do not ship to end users)
AGENTS.md
AI_CONTEXT.md
CLAUDE.md
HANDOFF.md
PROGRESS.md
WORKLOG.md
WORKLOG_archive/
WORKLOG_index.json
ISSUE_*.md
daily_bar_fix_plan.md
